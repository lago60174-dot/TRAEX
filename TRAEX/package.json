{
  "name": "forex-trading-backend",
  "version": "2.0.0",
  "description": "Production-grade Forex trading backend with Supabase & VAPID",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "db:generate": "supabase db diff -f",
    "db:push": "supabase db push",
    "functions:deploy": "supabase functions deploy",
    "deploy:all": "npm run build && npm run functions:deploy"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "uuid": "^9.0.1",
    "@supabase/supabase-js": "^2.39.0",
    "web-push": "^3.6.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.16",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/web-push": "^3.6.3",
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.10",
    "ts-jest": "^29.1.1",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "supabase": "^1.115.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}